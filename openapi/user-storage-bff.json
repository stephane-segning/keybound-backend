{
  "openapi": "3.0.3",
  "info": {
    "title": "Customer Registration Frontend API",
    "version": "1.0.0",
    "description": "Endpoints exposed to customer-facing frontends for registration and limit status."
  },
  "servers": [
    {
      "url": "https://api.example.com",
      "description": "Example production server"
    }
  ],
  "tags": [
    {
      "name": "KYC Documents",
      "description": "Upload endpoints for customer verification documents."
    },
    {
      "name": "Registration",
      "description": "Endpoints exposed for customer self-registration and status inquiry."
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Registration"
        ],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/registration/kyc/documents": {
      "post": {
        "tags": [
          "KYC Documents"
        ],
        "summary": "Create a KYC document upload",
        "description": "Authenticated customers request an S3 presigned URL to upload an ID or selfie document for manual review.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/KycDocumentUploadRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Upload URL created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KycDocumentUploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid document type, file, or size."
          },
          "401": {
            "description": "Unauthorized."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      }
    },
    "/api/registration/kyc/status": {
      "get": {
        "tags": [
          "Registration"
        ],
        "summary": "Get KYC status",
        "description": "Retrieve the KYC verification status and document metadata.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "Page number for document list (default 1)."
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1
            },
            "description": "Page size for document list (default 20)."
          }
        ],
        "responses": {
          "200": {
            "description": "KYC status information.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KycStatusResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          },
          "404": {
            "description": "Customer not found."
          }
        }
      }
    },
    "/api/registration/limits": {
      "get": {
        "tags": [
          "Registration"
        ],
        "summary": "Get transaction limits",
        "description": "Retrieve deposit/withdrawal limits based on the customer's KYC tier.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Limits and usage details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LimitsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          },
          "404": {
            "description": "Customer not found."
          }
        }
      }
    },
    "/api/registration/kyc/informations": {
      "patch": {
        "tags": [
          "Registration"
        ],
        "summary": "Patch KYC information",
        "description": "Update mutable KYC profile information for the authenticated user.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/KycInformationPatchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "KYC information updated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KycInformationResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          },
          "404": {
            "description": "Customer not found."
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "KycDocumentUploadRequest": {
        "type": "object",
        "required": [
          "documentType",
          "fileName",
          "mimeType",
          "contentLength"
        ],
        "properties": {
          "documentType": {
            "type": "string",
            "description": "One of id_front, id_back, selfie_with_id."
          },
          "fileName": {
            "type": "string"
          },
          "mimeType": {
            "type": "string",
            "description": "File MIME type (e.g., image/jpeg)."
          },
          "contentLength": {
            "type": "integer",
            "format": "int64",
            "description": "Expected file size in bytes."
          }
        }
      },
      "KycDocumentUploadResponse": {
        "type": "object",
        "properties": {
          "documentId": {
            "type": "string"
          },
          "documentType": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "uploadedAt": {
            "type": "string",
            "format": "date-time"
          },
          "fileName": {
            "type": "string"
          },
          "mimeType": {
            "type": "string"
          },
          "uploadUrl": {
            "type": "string",
            "format": "uri",
            "description": "Presigned S3 URL for direct upload."
          },
          "uploadMethod": {
            "type": "string",
            "description": "HTTP method to use when uploading to uploadUrl."
          },
          "uploadHeaders": {
            "type": "object",
            "description": "Headers that must be sent during upload.",
            "additionalProperties": {
              "type": "string"
            }
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "description": "When the presigned URL expires."
          },
          "s3Bucket": {
            "type": "string"
          },
          "s3Key": {
            "type": "string"
          }
        }
      },
      "KycStatusResponse": {
        "type": "object",
        "properties": {
          "kycTier": {
            "type": "integer"
          },
          "kycStatus": {
            "type": "string"
          },
          "documents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KycStatusResponseDocumentStatus"
            }
          },
          "requiredDocuments": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missingDocuments": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "page": {
            "type": "integer"
          },
          "pageSize": {
            "type": "integer"
          },
          "totalDocuments": {
            "type": "integer"
          }
        }
      },
      "KycStatusResponseDocumentStatus": {
        "type": "object",
        "properties": {
          "documentType": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "uploadedAt": {
            "type": "string",
            "format": "date-time"
          },
          "rejectionReason": {
            "type": "string"
          }
        }
      },
      "LimitsResponse": {
        "type": "object",
        "properties": {
          "kycTier": {
            "type": "integer"
          },
          "tierName": {
            "type": "string"
          },
          "limits": {
            "$ref": "#/components/schemas/LimitsResponseLimitsDto"
          },
          "usage": {
            "$ref": "#/components/schemas/LimitsResponseUsageDto"
          },
          "available": {
            "$ref": "#/components/schemas/LimitsResponseAvailableDto"
          },
          "allowedPaymentMethods": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "restrictedFeatures": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "currency": {
            "type": "string"
          }
        }
      },
      "LimitsResponseLimitsDto": {
        "type": "object",
        "properties": {
          "dailyDepositLimit": {
            "type": "number"
          },
          "dailyWithdrawalLimit": {
            "type": "number"
          },
          "perTransactionLimit": {
            "type": "number"
          },
          "monthlyTransactionLimit": {
            "type": "number"
          }
        }
      },
      "LimitsResponseUsageDto": {
        "type": "object",
        "properties": {
          "dailyDepositUsed": {
            "type": "number"
          },
          "dailyWithdrawalUsed": {
            "type": "number"
          },
          "monthlyUsed": {
            "type": "number"
          }
        }
      },
      "LimitsResponseAvailableDto": {
        "type": "object",
        "properties": {
          "depositRemaining": {
            "type": "number"
          },
          "withdrawalRemaining": {
            "type": "number"
          }
        }
      },
      "KycInformationPatchRequest": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string"
          },
          "dateOfBirth": {
            "type": "string"
          },
          "nationality": {
            "type": "string"
          }
        }
      },
      "KycInformationResponse": {
        "type": "object",
        "properties": {
          "externalId": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string"
          },
          "dateOfBirth": {
            "type": "string"
          },
          "nationality": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
