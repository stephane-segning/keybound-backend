{
  "id": "e2e-testing",
  "realm": "e2e-testing",
  "displayName": "Keybound E2E",
  "displayNameHtml": "<b>Keybound</b> E2E",
  "registrationAllowed": false,
  "rememberMe": false,
  "sslRequired": "none",
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": false,
  "requiredActions": [
    {
      "alias": "UPDATE_PROFILE",
      "name": "Update Profile",
      "providerId": "UPDATE_PROFILE",
      "enabled": false,
      "defaultAction": false,
      "priority": 10
    }
  ],
  "enabled": true,
  "components": {
    "org.keycloak.storage.UserStorageProvider": [
      {
        "id": "backend-user-storage",
        "name": "backend-user-storage",
        "providerId": "backend-user-storage",
        "config": {
          "enabled": [
            "true"
          ],
          "priority": [
            "0"
          ],
          "cachePolicy": [
            "DEFAULT"
          ]
        }
      }
    ]
  },
  "clients": [
    {
      "clientId": "web-vite",
      "name": "Keybound Vite Web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": []
    },
    {
      "clientId": "resource-server",
      "name": "Keybound Resource Server",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [],
      "directAccessGrantsEnabled": false
    },
    {
      "clientId": "test-client",
      "name": "Postman Client Credential",
      "surrogateAuthRequired": false,
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "some-secret",
      "bearerOnly": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "authorizationServicesEnabled": true
    }
  ]
}
