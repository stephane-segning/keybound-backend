# Agent Orchestration Commands

# Command: coordinate-agents
# Usage: opencode run --agent agent-orchestrator coordinate-agents
#
# Coordinates work across all specialized agents by:
# 1. Checking which agents are currently working
# 2. Identifying blocked agents and blockers
# 3. Scheduling next tasks based on dependencies
# 4. Optimizing for parallel execution when possible

echo "=== Agent Orchestration Status ==="
echo "Checking agent statuses and dependencies..."

# Get current git branch
echo "Current branch: $(git branch --show-current)"
echo ""

# Check which agents have open PRs or branches
echo "Active agent branches:"
git branch -a | grep "agent/" | sed 's/^/  - /'
echo ""

# Check for merge conflicts between agent branches
echo "Checking for inter-agent conflicts..."
conflict_count=0
for branch1 in $(git branch | grep "agent/" | sed 's/\* //'); do
    for branch2 in $(git branch | grep "agent/" | sed 's/\* //'); do
        if [ "$branch1" != "$branch2" ]; then
            git merge-tree $(git merge-base $branch1 $branch2) $branch1 $branch2 2>/dev/null | grep -q "<<<<<<"
            if [ $? -eq 0 ]; then
                echo "  ⚠️  Potential conflict: $branch1 ↔ $branch2"
                ((conflict_count++))
            fi
        fi
    done
done

if [ $conflict_count -eq 0 ]; then
    echo "  ✅ No conflicts detected between agent branches"
fi
echo ""

# Check dependency readiness
echo "Dependency readiness check:"
echo "  - flow-otp-master: $(opencode run --agent flow-otp-master validate-flow phone_otp >/dev/null 2>&1 && echo '✅ Ready' || echo '❌ Not ready')"
echo "  - flow-email-wizard: $(opencode run --agent flow-email-wizard validate-flow email_magic >/dev/null 2>&1 && echo '✅ Ready' || echo '❌ Not ready')"
echo "  - flow-deposit-builder: $(opencode run --agent flow-deposit-builder validate-flow first_deposit >/dev/null 2>&1 && echo '✅ Ready' || echo '❌ Not ready')"
echo ""

# Suggest next actions
echo "Recommended next actions:"
if ! opencode run --agent flow-otp-master validate-flow phone_otp >/dev/null 2>&1; then
    echo "  1. Run: opencode run --agent flow-otp-master implement-otp-flow"
fi
if ! opencode run --agent bff-generator generate-bff >/dev/null 2>&1; then
    echo "  2. Run: opencode run --agent bff-generator generate-bff"
fi
if ! opencode run --agent flow-architect validate-architecture >/dev/null 2>&1; then
    echo "  3. Run: flow-architect to define integration traits"
fi
echo ""

echo "=== Coordination Complete ==="