#!/bin/bash
# opencode command: track-progress
# Usage: opencode run --agent agent-orchestrator track-progress

echo "=== Tracking Agent Progress ==="
echo ""

# Overall project completion
echo "📊 Overall Project Status:"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

flows=("phone_otp" "email_magic" "first_deposit" "id_document" "address_proof")
completed=0
total=${#flows[@]}

for flow in "${flows[@]}"; do
    if opencode run --agent flow-orchestrator validate-flow "$flow" >/dev/null 2>&1; then
        echo "  ✅ $flow"
        ((completed++))
    else
        echo "  ⏳ $flow (in progress)"
    fi
done

echo ""
printf "Completion: %d/%d flows (%.0f%%)\n" $completed $total $((completed * 100 / total))
echo ""

# Agent-specific progress
echo "👥 Agent Progress:"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Check BFF generation
if opencode run --agent bff-generator generate-bff >/dev/null 2>&1; then
    echo "  ✅ bff-generator: BFF APIs generated"
else
    echo "  ⏳ bff-generator: In progress"
fi

# Check architecture
if git show-branch --list 2>/dev/null | grep -q "feat/architecture"; then
    echo "  ✅ flow-architect: Integration traits defined"
else
    echo "  ⏳ flow-architect: Working on trait design"
fi

# Check core flows
if opencode run --agent flow-otp-master validate-flow phone_otp >/dev/null 2>&1; then
    echo "  ✅ flow-otp-master: Phone OTP complete"
else
    echo "  ⏳ flow-otp-master: Implementing OTP flow"
fi

if opencode run --agent flow-email-wizard validate-flow email_magic >/dev/null 2>&1; then
    echo "  ✅ flow-email-wizard: Email magic complete"
else
    echo "  ⏳ flow-email-wizard: Implementing email flow"
fi

# Check advanced flows
if opencode run --agent flow-deposit-builder validate-flow first_deposit >/dev/null 2>&1; then
    echo "  ✅ flow-deposit-builder: Deposit flow complete"
else
    echo "  ⏳ flow-deposit-builder: Working on deposit flow"
fi

# Check testing
if git log --grep="test" --oneline 2>/dev/null | wc -l | grep -qE "[5-9]|[0-9]{2,}"; then
    echo "  ✅ test-engineer: Tests written"
else
    echo "  ⏳ test-engineer: Writing tests"
fi

echo ""

echo "📈 Blockers & Risks:"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Check for long-running branches
old_branches=$(git for-each-ref --format='%(refname:short) %(committerdate:short)' refs/heads/ | grep "agent/" | awk '$2 < "2026-03-10" {print $1}' | wc -l | tr -d ' ')
if [ "$old_branches" -gt 2 ]; then
    echo "  ⚠️  $old_branches old agent branches - consider merging"
fi

# Check for agents waiting on others
echo "  - Agents can work in parallel where no dependencies exist"
echo 

echo ""
echo "🎯 Success Metrics:"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
cargo tarpaulin --out StdOut 2>/dev/null | grep -E "^coverage:" || echo "  Coverage: Run 'cargo tarpaulin' for details"
cargo clippy --all-targets --all-features -- -D warnings 2>&1 | grep -c "warning:" | xargs -I {} echo "  Clippy warnings: {} (target: 0)"
echo ""

echo "=== Progress Tracking Complete ==="
echo ""
echo "Next review recommended: After 1-2 agent tasks complete"