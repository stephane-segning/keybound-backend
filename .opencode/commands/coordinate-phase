#!/bin/bash
# opencode command: coordinate-phase
# Usage: opencode run --agent agent-orchestrator coordinate-phase <phase-name>

PHASE_NAME=${1:-""}

if [ -z "$PHASE_NAME" ]; then
    echo "Usage: opencode run --agent agent-orchestrator coordinate-phase <phase-name>"
    echo ""
    echo "Available phases:"
    echo "  foundation     - Code generation and architecture setup"
    echo "  core-flows     - Phone OTP and Email Magic flows"
    echo "  advanced       - First Deposit and Document flows"
    echo "  testing        - Unit and integration tests"
    echo "  delivery       - Final lint and documentation"
    exit 1
fi

echo "=== Coordinating Phase: $PHASE_NAME ==="
echo ""

case $PHASE_NAME in
    foundation)
        echo "📦 Running Foundation Phase..."
        echo ""
        echo "Step 1: Generate BFF OpenAPI code"
        opencode run --agent bff-generator generate-bff
        echo ""
        echo "Step 2: Verify architecture readiness"
        echo "   - Check integration traits exist"
        echo "   - Verify flow patterns are documented"
        echo ""
        echo "Agents involved: bff-generator, flow-architect"
        ;;
        
    core-flows)
        echo "🔧 Running Core Flows Phase..."
        echo ""
        echo "Step 1: Implement Phone OTP flow"
        echo "   - Generate OTP with Argon2 hashing"
        echo "   - Integrate SMS provider"
        opencode run --agent flow-otp-master implement-otp-flow
        echo ""
        echo "Step 2: Test Phone OTP flow"
        opencode run --agent test-engineer test-flow phone_otp
        echo ""
        echo "Step 3: Implement Email Magic flow"
        echo "   - Generate magic links with JWT"
        echo "   - Integrate email provider"
        # opencode run --agent flow-email-wizard implement-email-flow
        echo ""
        echo "Agents involved: flow-otp-master, flow-email-wizard, test-engineer"
        ;;
        
    advanced)
        echo "🏗️  Running Advanced Flows Phase..."
        echo ""
        echo "Step 1: Implement First Deposit flow"
        echo "   - Payment request creation"
        echo "   - Staff confirmation workflow"
        echo "   - CUSS integration"
        opencode run --agent flow-deposit-builder validate-flow first_deposit
        echo ""
        echo "Step 2: Implement Document flows"
        echo "   - ID document upload"
        echo "   - Address proof upload"
        echo "   - Admin verification workflow"
        opencode run --agent integration-specialist validate-flow id_document
        opencode run --agent integration-specialist validate-flow address_proof
        echo ""
        echo "Agents involved: flow-deposit-builder, integration-specialist"
        ;;
        
    testing)
        echo "🧪 Running Testing Phase..."
        echo ""
        echo "Step 1: Unit tests for all flows"
        for flow in phone_otp email_magic first_deposit id_document address_proof; do
            if [ -f "app/crates/backend-flow-sdk/src/flows/${flow}.rs" ]; then
                echo "   Testing $flow..."
                opencode run --agent test-engineer test-flow "$flow"
            fi
        done
        echo ""
        echo "Step 2: Integration tests for orchestration"
        # Run integration test suite
        echo ""
        echo "Step 3: Coverage report"
        opencode run --agent test-engineer run-coverage-report
        echo ""
        echo "Agents involved: test-engineer"
        ;;
        
    delivery)
        echo "🚀 Running Delivery Phase..."
        echo ""
        echo "Step 1: Code quality checks"
        opencode run --agent project-closer final-lint
        echo ""
        echo "Step 2: Update documentation"
        opencode run --agent project-closer update-documentation
        echo ""
        echo "Step 3: Final validation"
        opencode run --agent flow-orchestrator check-workspace
        echo ""
        echo "Agents involved: project-closer, flow-orchestrator"
        ;;
        
    *)
        echo "❌ Unknown phase: $PHASE_NAME"
        echo ""
        echo "Available phases: foundation, core-flows, advanced, testing, delivery"
        exit 1
        ;;
esac

echo ""
echo "=== Phase $PHASE_NAME Coordination Complete ==="