#!/bin/bash
# opencode command: schedule-work
# Usage: opencode run --agent agent-orchestrator schedule-work <agent-name> <task>

AGENT_NAME=${1:-""}
TASK=${2:-""}

echo "=== Scheduling Agent Work ==="

if [ -z "$AGENT_NAME" ] || [ -z "$TASK" ]; then
    echo "Usage: opencode run --agent agent-orchestrator schedule-work <agent-name> <task>"
    echo "Example: opencode run --agent agent-orchestrator schedule-work flow-otp-master 'implement phone otp'"
    exit 1
fi

echo "Scheduling work for $AGENT_NAME: $TASK"
echo ""

# Check if agent is blocked
echo "Checking dependencies for $AGENT_NAME..."
case "$AGENT_NAME" in
    flow-otp-master)
        if ! git show-branch --list | grep -q "origin/feat/flow-architecture-complete"; then
            echo "  ⚠️  Blocked: Waiting for flow-architect"
            echo "  Action: Have flow-architect complete integration traits first"
            exit 1
        fi
        ;;
    flow-email-wizard)
        if ! opencode run --agent flow-otp-master validate-flow phone_otp >/dev/null 2>&1; then
            echo "  ⚠️  Blocked: Phone OTP patterns not established"
            echo "  Action: Complete phone_otp flow first for pattern reference"
            exit 1
        fi
        ;;
    test-engineer)
        if ! opencode run --agent flow-otp-master validate-flow phone_otp >/dev/null 2>&1; then
            echo "  ⚠️  Blocked: No flows to test yet"
            echo "  Action: Complete at least one flow implementation first"
            exit 1
        fi
        ;;
esac

echo "  ✅ No blocking dependencies detected"
echo ""

# Schedule based on workload
echo "Current agent workload:"
active_branches=$(git branch | grep "agent/" | wc -l | tr -d ' ')
echo "  - Active agent branches: $active_branches"
echo ""

if [ "$active_branches" -lt 3 ]; then
    echo "✅ Scheduling: $AGENT_NAME can start immediately"
    echo "  Recommended: Start work on branch agent/$AGENT_NAME/$TASK"
    opencode run --agent $AGENT_NAME $TASK
else
    echo "⚠️  Schedule recommendation:"
    echo "  - Wait for 1-2 agents to complete and merge"
    echo "  - Start $AGENT_NAME in parallel with non-conflicting agents"
    echo "  - Use: git checkout -b agent/$AGENT_NAME/$TASK"
fi

echo ""
echo "=== Scheduling Complete ==="